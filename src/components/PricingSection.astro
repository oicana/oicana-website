---
import { Icon } from "@astrojs/starlight/components";
import type { StarlightIcon } from "@astrojs/starlight/types";
import { TIERS } from "../config/creem";

const TIER_ICONS: Record<string, StarlightIcon> = {
	Startup: "rocket",
	Scaleup: "star",
	Enterprise: "sun",
};
---

<section id="pricing" class="pricing-section">
    <div class="pricing-panel pricing-panel--noncommercial not-content">
        <div class="pricing-panel-header">
            <h4 class="pricing-panel-label">Non-commercial</h4>
            <span class="pricing-panel-tag">Free</span>
        </div>
        <p class="pricing-panel-description">
            Oicana is source-available under the{" "}
            <a href="https://polyformproject.org/licenses/noncommercial/1.0.0">
                PolyForm Noncommercial License 1.0.0
            </a>. Any non-commercial use is free — personal projects, hobby use,
            research, and education. The license also explicitly permits use by
            charitable organizations, educational institutions, public research
            organizations, and government institutions, regardless of their
            funding source.
        </p>
        <a
            class="pricing-panel-link"
            href="https://github.com/oicana/oicana/blob/main/LICENSE.md"
        >
            View license →
        </a>
    </div>

    <div class="pricing-panel pricing-panel--commercial not-content">
        <div class="pricing-panel-header">
            <h4 class="pricing-panel-label">Commercial</h4>
            <span class="pricing-panel-tag">Free 30-day trial</span>
        </div>
        <div class="commercial-intro">
            <p class="pricing-panel-description">
                Flat fee, no metering. Licenses are
                <strong> per application</strong>, priced by company size. Pay
                once for unlimited seats, environments, and documents. Every
                subscription includes all Oicana components like the CLI and the
                integrations.
            </p>

            <div
                class="billing-toggle"
                role="radiogroup"
                aria-label="Billing cycle"
            >
                <button
                    type="button"
                    class="billing-option is-active"
                    role="radio"
                    aria-checked="true"
                    data-billing-cycle="monthly"
                >
                    Monthly
                </button>
                <button
                    type="button"
                    class="billing-option"
                    role="radio"
                    aria-checked="false"
                    data-billing-cycle="annual"
                >
                    Annual <span class="billing-save">Save 15%</span>
                </button>
            </div>
        </div>

        <div class="tier-grid">
            {
                TIERS.map((tier) => {
                    const resolvePrice = (value: string) =>
                        value && value !== "TODO" ? value : "";
                    const monthlyPrice = resolvePrice(tier.prices.monthly);
                    const annualPrice = resolvePrice(tier.prices.annual);
                    const hasAnyPrice = Boolean(monthlyPrice || annualPrice);
                    return (
                        <div
                            class="tier-card"
                            data-tier-name={tier.name}
                            data-price-monthly={monthlyPrice}
                            data-price-annual={annualPrice}
                            data-checkout-monthly={tier.checkoutUrls.monthly}
                            data-checkout-annual={tier.checkoutUrls.annual}
                        >
                            <div class="tier-header">
                                <h3 class="tier-name">{tier.name}</h3>
                                <Icon
                                    name={TIER_ICONS[tier.name]}
                                    class="tier-icon"
                                    size="1.5rem"
                                />
                            </div>
                            <p class="tier-description">{tier.description}</p>
                            <p class="tier-criteria">{tier.criteria}</p>
                            {hasAnyPrice ? (
                                <>
                                    <p class="tier-price" data-role="price">
                                        <span
                                            class="tier-price-amount"
                                            data-role="price-amount"
                                        >
                                            {monthlyPrice || "—"}
                                        </span>
                                        <span
                                            class="tier-price-cadence"
                                            data-role="price-cadence"
                                        >
                                            / month
                                        </span>
                                    </p>
                                    <button type="button" class="tier-checkout">
                                        Buy subscription
                                    </button>
                                </>
                            ) : (
                                <p class="tier-price coming-soon">
                                    Coming soon
                                </p>
                            )}
                        </div>
                    );
                })
            }
        </div>

        <p class="pricing-manage">
            Already subscribed?
            <a
                href="https://creem.io/my-orders/login"
                target="_blank"
                rel="noopener noreferrer"
            >
                Manage your subscriptions.
            </a>
        </p>

        <p class="pricing-legal">
            Our order processes are conducted by our merchant of record Creem.
        </p>
    </div>

    <div class="pricing-panel pricing-panel--faq not-content">
        <div class="pricing-panel-header">
            <h4 class="pricing-panel-label">FAQ</h4>
        </div>

        <details class="faq-item">
            <summary>What counts as one application?</summary>
            <div class="faq-body">
                <p>
                    An application is one distinct software product or internal
                    tool, regardless of how many services, environments, or
                    users it has. See{" "}
                    <a
                        href="/terms-of-service/#43-per-application-licensing"
                    >
                        Section 4.2 of our Terms of Service
                    </a>
                    {" "}for the binding definition.
                </p>
                <ul class="application-cases">
                    <li>
                        <span class="case-description">
                            A SaaS with multiple microservices generating
                            documents
                        </span>
                        <span class="case-count">1 application</span>
                    </li>
                    <li>
                        <span class="case-description">
                            Web, iOS, and Android apps sharing one backend
                        </span>
                        <span class="case-count">1 application</span>
                    </li>
                    <li>
                        <span class="case-description">
                            Production, staging, and dev environments
                        </span>
                        <span class="case-count">1 application</span>
                    </li>
                    <li>
                        <span class="case-description">
                            A customer-facing SaaS plus a separate internal
                            admin tool
                        </span>
                        <span class="case-count">2 applications</span>
                    </li>
                    <li>
                        <span class="case-description">
                            One codebase white-labeled and sold as 3 separate
                            products (reach out to us for a custom solution)
                        </span>
                        <span class="case-count">3 applications</span>
                    </li>
                </ul>
            </div>
        </details>

        <details class="faq-item">
            <summary>Can I try Oicana commercially before buying?</summary>
            <div class="faq-body">
                <p>
                    Yes — commercial evaluation is free for 30 days from your
                    first commercial use. You can follow the getting-started
                    guide, build a proof-of-concept integration, and test
                    Oicana internally without a subscription. Documents
                    generated during evaluation must not be distributed
                    externally or used in production. See{" "}
                    <a href="/terms-of-service/#42-evaluation-use">
                        Section 4.2 of our Terms of Service
                    </a>
                    {" "}for the full terms.
                </p>
            </div>
        </details>

        <details class="faq-item">
            <summary>Do you offer a money-back guarantee?</summary>
            <div class="faq-body">
                <p>
                    Yes — we offer a 30-day money-back guarantee. If Oicana
                    isn't the right fit, just email{" "}
                    <a href="mailto:support@oicana.com">support@oicana.com</a>
                    {" "}within 30 days of your purchase and we'll refund you
                    in full. See our{" "}
                    <a href="/refund-policy/">Refund Policy</a> for the full
                    terms.
                </p>
            </div>
        </details>
    </div>
</section>

<div class="thanks-modal" id="thanks-modal" hidden>
    <div class="thanks-modal-backdrop" data-role="close"></div>
    <div
        class="thanks-modal-panel"
        role="dialog"
        aria-modal="true"
        aria-labelledby="thanks-title"
    >
        <button
            type="button"
            class="thanks-modal-close"
            aria-label="Close"
            data-role="close"
        >
            ×
        </button>
        <h3 id="thanks-title" class="thanks-modal-title">
            Thank you for your purchase!
        </h3>
        <p>
            Ready to dive in? Head to the{" "}
            <a href="/docs/getting-started/1-setup/">getting started guide</a>
            {" "}to set up Oicana in your project.
        </p>
        <p>
            A confirmation email from Creem with your receipt should arrive in
            your inbox shortly.
        </p>
        <p>
            Not happy? You're covered by our <strong
                >30-day money-back guarantee</strong
            > — just contact us at{" "}
            <a href="mailto:support@oicana.com">support@oicana.com</a>. You can
            manage your subscription anytime through the{" "}
            <a
                href="https://creem.io/my-orders/login"
                target="_blank"
                rel="noopener noreferrer"
            >
                Creem customer portal
            </a>.
        </p>
    </div>
</div>

<script>
    type BillingCycle = "monthly" | "annual";

    interface Card {
        amountEl: HTMLElement;
        cadenceEl: HTMLElement;
        button: HTMLButtonElement | null;
        prices: Record<BillingCycle, string>;
        checkoutUrls: Record<BillingCycle, string>;
    }

    const cards: Card[] = Array.from(
        document.querySelectorAll<HTMLElement>(".tier-card"),
    )
        .map((root) => {
            const amountEl = root.querySelector<HTMLElement>(
                '[data-role="price-amount"]',
            );
            const cadenceEl = root.querySelector<HTMLElement>(
                '[data-role="price-cadence"]',
            );
            if (!amountEl || !cadenceEl) return null;
            return {
                amountEl,
                cadenceEl,
                button: root.querySelector<HTMLButtonElement>(".tier-checkout"),
                prices: {
                    monthly: root.dataset.priceMonthly ?? "",
                    annual: root.dataset.priceAnnual ?? "",
                },
                checkoutUrls: {
                    monthly: root.dataset.checkoutMonthly ?? "",
                    annual: root.dataset.checkoutAnnual ?? "",
                },
            } satisfies Card;
        })
        .filter((card): card is Card => card !== null);

    let selectedCycle: BillingCycle = "monthly";

    function render() {
        for (const card of cards) {
            const url = card.checkoutUrls[selectedCycle];
            const price = card.prices[selectedCycle];
            card.amountEl.textContent = price || "—";
            card.cadenceEl.textContent =
                selectedCycle === "annual" ? "/ year" : "/ month";
            if (card.button) {
                card.button.disabled = !url || !price;
            }
        }
    }

    render();

    const billingOptions =
        document.querySelectorAll<HTMLButtonElement>(".billing-option");

    for (const option of billingOptions) {
        option.addEventListener("click", () => {
            const cycle = option.dataset.billingCycle as
                | BillingCycle
                | undefined;
            if (!cycle || cycle === selectedCycle) return;
            selectedCycle = cycle;
            for (const other of billingOptions) {
                const active = other === option;
                other.classList.toggle("is-active", active);
                other.setAttribute("aria-checked", active ? "true" : "false");
            }
            render();
        });
    }

    for (const card of cards) {
        card.button?.addEventListener("click", () => {
            const url = card.checkoutUrls[selectedCycle];
            if (!url) return;
            window.open(url, "_blank", "noopener,noreferrer");
        });
    }

    const currentUrl = new URL(window.location.href);
    if (currentUrl.searchParams.get("bought") === "true") {
        const modal = document.getElementById("thanks-modal");
        if (modal) {
            modal.hidden = false;
            const closeModal = () => {
                modal.hidden = true;
                const cleanUrl = new URL(window.location.href);
                cleanUrl.searchParams.delete("bought");
                window.history.replaceState({}, "", cleanUrl.toString());
            };
            for (const el of modal.querySelectorAll<HTMLElement>(
                '[data-role="close"]',
            )) {
                el.addEventListener("click", closeModal);
            }
            document.addEventListener("keydown", (e) => {
                if (e.key === "Escape" && !modal.hidden) closeModal();
            });
        }
    }
</script>

<style>
    .pricing-section {
        margin-top: 2rem;
    }

    .pricing-panel {
        margin: 1.5rem 0;
        padding: 1.5rem;
        border: 1px solid var(--sl-color-gray-5);
        border-radius: 1rem;
        background: var(--sl-color-gray-7, var(--sl-color-gray-6));
    }

    .pricing-panel-header {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        margin: 0 0 0.75rem;
    }

    .pricing-panel-label {
        margin: 0;
        font-size: var(--sl-text-lg);
        font-weight: 700;
    }

    .pricing-panel-tag {
        font-size: var(--sl-text-sm);
        font-weight: 600;
        color: var(--sl-color-green-high);
        border: 1px solid var(--sl-color-green-high);
        padding: 0.15rem 0.55rem;
        border-radius: 999px;
    }

    .pricing-panel-description {
        color: var(--sl-color-gray-2);
        margin: 0 0 1rem;
    }

    .pricing-panel-link {
        display: inline-block;
        font-weight: 600;
    }

    .commercial-intro {
        display: flex;
        flex-direction: column;
        gap: 1rem;
        margin-bottom: 1.25rem;
    }

    .commercial-intro .pricing-panel-description {
        margin: 0;
    }

    @media (min-width: 48rem) {
        .commercial-intro {
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
            gap: 1.5rem;
        }

        .commercial-intro .pricing-panel-description {
            flex: 1;
        }
    }

    .billing-toggle {
        display: inline-flex;
        gap: 0.25rem;
        padding: 0.25rem;
        border: 1px solid var(--sl-color-gray-5);
        border-radius: 0.625rem;
        background: var(--sl-color-bg, transparent);
        flex-shrink: 0;
        align-self: flex-start;
    }

    .billing-option {
        appearance: none;
        background: transparent;
        border: none;
        color: var(--sl-color-gray-2);
        font: inherit;
        font-size: var(--sl-text-sm);
        padding: 0.5rem 0.875rem;
        border-radius: 0.375rem;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
    }

    .billing-option.is-active {
        background: var(--sl-color-gray-6);
        color: var(--sl-color-white);
    }

    .billing-option:focus-visible {
        outline: 2px solid var(--sl-color-text-accent);
        outline-offset: 2px;
    }

    .billing-save {
        font-size: var(--sl-text-xs);
        color: var(--sl-color-green-high);
        font-weight: 600;
    }

    .tier-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        margin: 0;
        align-items: stretch;
    }

    @media (max-width: 48rem) {
        .tier-grid {
            grid-template-columns: 1fr;
        }
    }

    .tier-card {
        border: 1px solid var(--sl-color-gray-5);
        border-radius: 0.75rem;
        padding: 1.5rem;
        display: grid;
        grid-template-rows: auto auto auto 1fr auto;
    }

    .tier-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin: 0 0 0.25rem;
    }

    .tier-icon {
        color: var(--sl-color-text-accent);
        flex-shrink: 0;
    }

    .tier-name {
        margin: 0;
        font-size: var(--sl-text-lg);
    }

    .tier-description {
        color: var(--sl-color-gray-2);
        margin: 0 0 0.5rem;
        font-size: var(--sl-text-sm);
    }

    .tier-criteria {
        color: var(--sl-color-gray-3);
        font-size: var(--sl-text-xs);
        margin: 0 0 1rem;
    }

    .tier-price {
        margin: 0 0 1rem;
        display: flex;
        align-items: baseline;
        flex-wrap: wrap;
    }

    .tier-price-amount {
        font-size: var(--sl-text-2xl);
        font-weight: 700;
    }

    .tier-price-cadence {
        color: var(--sl-color-gray-3);
        font-size: var(--sl-text-sm);
        margin-left: 0.25rem;
    }

    .tier-price.coming-soon {
        color: var(--sl-color-gray-3);
        font-size: var(--sl-text-lg);
        display: block;
    }

    .tier-checkout {
        appearance: none;
        border: 1px solid var(--sl-color-text-accent);
        background: var(--sl-color-text-accent);
        color: var(--sl-color-black);
        font-weight: 600;
        font-size: var(--sl-text-base);
        padding: 0.625rem 1rem;
        border-radius: 0.5rem;
        cursor: pointer;
        transition: filter 0.15s ease;
    }

    .tier-checkout:hover:not(:disabled) {
        filter: brightness(1.1);
    }

    .tier-checkout:disabled {
        opacity: 0.5;
        cursor: not-allowed;
    }

    .tier-checkout:focus-visible {
        outline: 2px solid var(--sl-color-text-accent);
        outline-offset: 2px;
    }

    .faq-item {
        border-top: 1px solid var(--sl-color-gray-5);
    }

    .faq-item:first-of-type {
        border-top: none;
    }

    .faq-item summary {
        list-style: none;
        cursor: pointer;
        font-weight: 600;
        color: var(--sl-color-white);
        padding: 0.875rem 0;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
    }

    .faq-item summary::-webkit-details-marker {
        display: none;
    }

    .faq-item summary::after {
        content: "+";
        font-size: 1.25rem;
        line-height: 1;
        color: var(--sl-color-gray-3);
        flex-shrink: 0;
    }

    .faq-item[open] summary::after {
        content: "−";
    }

    .faq-item summary:focus-visible {
        outline: 2px solid var(--sl-color-text-accent);
        outline-offset: 2px;
        border-radius: 0.25rem;
    }

    .faq-body {
        padding: 0 0 1rem;
        color: var(--sl-color-gray-2);
    }

    .faq-body > p {
        margin: 0 0 1.25rem;
    }

    .faq-body > p:last-child {
        margin-bottom: 0;
    }

    .application-cases {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .application-cases li {
        display: flex;
        flex-wrap: wrap;
        justify-content: space-between;
        align-items: baseline;
        gap: 0.5rem 1.5rem;
        padding: 0.75rem 0;
        border-bottom: 1px dashed var(--sl-color-gray-5);
        color: var(--sl-color-gray-2);
        font-size: var(--sl-text-sm);
    }

    .application-cases li:last-child {
        border-bottom: none;
        padding-bottom: 0;
    }

    .application-cases li:first-child {
        padding-top: 0;
    }

    .case-description {
        flex: 1 1 60%;
        min-width: 0;
    }

    .case-count {
        font-weight: 600;
        color: var(--sl-color-white);
        white-space: nowrap;
        flex-shrink: 0;
    }

    .pricing-manage {
        font-size: var(--sl-text-sm);
        margin: 1rem 0 0;
        text-align: center;
    }

    .pricing-legal {
        color: var(--sl-color-gray-3);
        font-size: var(--sl-text-xs);
        margin: 0.5rem 0 0;
        text-align: center;
    }

    .tier-features {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .tier-features li {
        padding: 0.25rem 0;
        font-size: var(--sl-text-sm);
        color: var(--sl-color-gray-2);
    }

    .tier-features li::before {
        content: "✓ ";
        color: var(--sl-color-green-high);
    }

    .thanks-modal[hidden] {
        display: none;
    }

    .thanks-modal {
        position: fixed;
        inset: 0;
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .thanks-modal-backdrop {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.6);
    }

    .thanks-modal-panel {
        position: relative;
        max-width: 32rem;
        width: 100%;
        background: var(--sl-color-bg);
        border: 1px solid var(--sl-color-gray-5);
        border-radius: 1rem;
        padding: 2rem;
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
    }

    .thanks-modal-close {
        position: absolute;
        top: 0.5rem;
        right: 0.75rem;
        background: transparent;
        border: none;
        font-size: 1.75rem;
        line-height: 1;
        cursor: pointer;
        color: var(--sl-color-gray-3);
        padding: 0.25rem 0.5rem;
    }

    .thanks-modal-close:hover {
        color: var(--sl-color-white);
    }

    .thanks-modal-title {
        margin: 0 0 1rem;
    }
</style>
