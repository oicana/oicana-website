---
import { Icon } from "@astrojs/starlight/components";
import type { StarlightIcon } from "@astrojs/starlight/types";
import { TIERS } from "../config/paddle";

const TIER_ICONS: Record<string, StarlightIcon> = {
	Starter: "rocket",
	Business: "star",
	Enterprise: "sun",
};
---

<section id="pricing" class="pricing-section">
    <p class="pricing-intro">
        For commercial use, licenses are <strong>per project</strong>, based on company size. Every subscription includes all Oicana components like the CLI and the integrations.
    </p>

    <div class="tier-grid not-content">
        {
            TIERS.map((tier) => (
                <div class="tier-card">
                    <div class="tier-header">
                        <h4 class="tier-name">{tier.name}</h4>
                        <Icon name={TIER_ICONS[tier.name]} class="tier-icon" size="1.5rem" />
                    </div>
                    <p class="tier-description">{tier.description}</p>
                    <p class="tier-criteria">{tier.criteria}</p>
                    <p class="tier-price coming-soon">Coming soon</p>
                </div>
            ))
        }
    </div>
</section>

<style>
    .pricing-section {
        margin-top: 2rem;
    }

    .pricing-intro {
        color: var(--sl-color-gray-2);
    }

    .tier-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1.5rem;
        margin: 1.5rem 0;
        align-items: stretch;
    }

    @media (max-width: 48rem) {
        .tier-grid {
            grid-template-columns: 1fr;
        }
    }

    .tier-card {
        border: 1px solid var(--sl-color-gray-5);
        border-radius: 0.75rem;
        padding: 1.5rem;
        display: grid;
        grid-template-rows: auto auto auto auto 1fr;
    }

    .tier-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 0.75rem;
        margin: 0 0 0.25rem;
    }

    .tier-icon {
        color: var(--sl-color-text-accent);
        flex-shrink: 0;
    }

    .tier-name {
        margin: 0;
        font-size: var(--sl-text-lg);
    }

    .tier-description {
        color: var(--sl-color-gray-2);
        margin: 0 0 0.5rem;
        font-size: var(--sl-text-sm);
    }

    .tier-criteria {
        color: var(--sl-color-gray-3);
        font-size: var(--sl-text-xs);
        margin: 0 0 1rem;
    }

    .tier-price {
        font-size: var(--sl-text-2xl);
        font-weight: 700;
        margin: 0 0 1rem;
    }

    .tier-price.coming-soon {
        color: var(--sl-color-gray-3);
        font-size: var(--sl-text-lg);
    }

    .tier-features {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .tier-features li {
        padding: 0.25rem 0;
        font-size: var(--sl-text-sm);
        color: var(--sl-color-gray-2);
    }

    .tier-features li::before {
        content: "✓ ";
        color: var(--sl-color-green-high);
    }
</style>
