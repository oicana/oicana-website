# Creem hosted Checkout Link URLs (create each in the Creem dashboard).
# Values starting with "creem_test_" keys produce test checkout URLs; live
# keys produce production URLs. Astro automatically loads .env.development
# for `astro dev` and .env.production for `astro build`.

PUBLIC_CREEM_CHECKOUT_STARTER_MONTHLY=
PUBLIC_CREEM_CHECKOUT_STARTER_ANNUAL=

PUBLIC_CREEM_CHECKOUT_BUSINESS_MONTHLY=
PUBLIC_CREEM_CHECKOUT_BUSINESS_ANNUAL=

PUBLIC_CREEM_CHECKOUT_ENTERPRISE_MONTHLY=
PUBLIC_CREEM_CHECKOUT_ENTERPRISE_ANNUAL=
